---
import { getUi } from '../i18n/ui';
import { localize, type Locale } from '../i18n/utils';
import { SITE } from '../consts';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const ui = getUi(locale);
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-gold-600/30 bg-ink-900 text-parchment-100">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
      <div>
        <p class="font-display text-2xl font-bold text-gold-400">⚜ Romestead</p>
        <p class="mt-2 max-w-sm text-sm text-parchment-200" data-i18n="footer.tagline">
          {ui['footer.tagline']}
        </p>
      </div>
      <nav class="flex flex-col gap-2 text-sm">
        <a href={localize(locale, '/guides')} class="hover:text-gold-400" data-i18n="nav.guides">{ui['nav.guides']}</a>
        <a href={localize(locale, '/heroes')} class="hover:text-gold-400" data-i18n="nav.heroes">{ui['nav.heroes']}</a>
        <a href={localize(locale, '/world')} class="hover:text-gold-400" data-i18n="nav.world">{ui['nav.world']}</a>
      </nav>
    </div>
    <p class="mt-8 text-xs text-parchment-300/70" data-i18n="footer.built">{ui['footer.built']}</p>
    <p class="mt-1 text-xs text-parchment-300/70">© {year} {SITE.author}. <span data-i18n="footer.rights">{ui['footer.rights']}</span></p>
  </div>
</footer>
