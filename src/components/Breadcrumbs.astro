---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  {items.map((c, i) => (
    <span>
      {i > 0 && <span class="sep">/</span>}
      {c.href
        ? <a href={c.href}>{c.label}</a>
        : <span class="current">{c.label}</span>}
    </span>
  ))}
</nav>
