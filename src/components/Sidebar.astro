---
import { link, LOCALES, type Locale } from '../i18n/utils';
import { GUIDES } from '../content/guides';
import { getUi } from '../i18n/ui';

interface Props {
  locale: Locale;
  path: string; // current path without locale, e.g. '/guides/survive-night'
}
const { locale, path } = Astro.props;
const ui = getUi(locale);
const isActive = (p: string) => (p === '/' ? path === '/' : path === p || path.startsWith(p + '/'));

// Logical guide groupings (mirrors the Header dropdown order).
const guideGroups = ([
  ['survival', 'cat.survival'],
  ['building', 'cat.building'],
  ['mechanic', 'cat.mechanic'],
  ['walkthrough', 'cat.walkthrough'],
  ['resources', 'cat.resources'],
  ['food', 'cat.food'],
  ['bestiary', 'cat.bestiary'],
  ['buildings', 'cat.buildings'],
  ['gods', 'cat.gods'],
  ['boss', 'cat.boss'],
  ['coop', 'cat.coop'],
  ['faq', 'cat.faq'],
] as const).map(([cat, labelKey]) => ({
  label: ui[labelKey],
  items: GUIDES.filter((g) => g.category === cat).map((g) => ({
    title: g.title[locale] ?? g.title.en,
    url: link(locale, `/guides/${g.slug}`),
    active: isActive(`/guides/${g.slug}`),
  })),
})).filter((g) => g.items.length);
---
<aside class="sidebar">
  <!-- LEARN -->
  <div class="sidebar__group">
    <p class="sidebar__heading">{ui['nav.guides']}</p>
    <ul>
      <li>
        <a href={link(locale, '/guides')} class={isActive('/guides') ? 'is-active' : ''}>{ui['allGuides']}</a>
      </li>
      {guideGroups.map((group) => (
        <li class="sidebar__subgroup">
          <p class="sidebar__subheading">{group.label}</p>
          <ul>
            {group.items.map((i) => (
              <li>
                <a href={i.url} class={i.active ? 'is-active' : ''}>{i.title}</a>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </div>

  <!-- EXPLORE -->
  <div class="sidebar__group">
    <p class="sidebar__heading">{ui['nav.world']}</p>
    <ul>
      <li><a href={link(locale, '/world')} class={isActive('/world') ? 'is-active' : ''}>{ui['nav.world']}</a></li>
    </ul>
  </div>
  <div class="sidebar__group">
    <p class="sidebar__heading">{ui['nav.map']}</p>
    <ul>
      <li><a href={link(locale, '/map')} class={isActive('/map') ? 'is-active' : ''}>{ui['nav.map']}</a></li>
    </ul>
  </div>

  <!-- ENCOUNTER -->
  <div class="sidebar__group">
    <p class="sidebar__heading">{ui['nav.heroes']}</p>
    <ul>
      <li><a href={link(locale, '/heroes')} class={isActive('/heroes') ? 'is-active' : ''}>{ui['nav.heroes']}</a></li>
    </ul>
  </div>

  <!-- HELP -->
  <div class="sidebar__group">
    <p class="sidebar__heading">{ui['nav.faq']}</p>
    <ul>
      <li><a href={link(locale, '/faq')} class={isActive('/faq') ? 'is-active' : ''}>{ui['nav.faq']}</a></li>
    </ul>
  </div>
</aside>
