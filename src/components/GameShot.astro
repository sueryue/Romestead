---
import type { Locale } from '../i18n/utils';
import { pick } from '../i18n/utils';
import { getUi } from '../i18n/ui';

interface Props {
  scene: 'base' | 'hero-roster' | 'formation' | 'beast' | 'raid';
  locale: Locale;
  caption?: Record<Locale, string>;
  alt?: string;
  class?: string;
}
const { scene, locale, caption, alt = 'In-game screenshot of Romestead', class: cls = '' } = Astro.props;

const ui = getUi(locale);
const label: Record<string, string> = {
  base: ui['scene.base'],
  'hero-roster': ui['scene.heroRoster'],
  formation: ui['scene.formation'],
  beast: ui['scene.beast'],
  raid: ui['scene.raid'],
};

// Hero roster data for the roster scene
const roster = [
  { init: 'A', tier: 'S', el: 'Light', col: 'oklch(0.90 0.06 95)', name: 'Aurelia' },
  { init: 'D', tier: 'S', el: 'Fire', col: 'oklch(0.72 0.17 35)', name: 'Drusus' },
  { init: 'O', tier: 'S', el: 'Shadow', col: 'oklch(0.58 0.10 300)', name: 'Octavia' },
  { init: 'T', tier: 'A', el: 'Earth', col: 'oklch(0.72 0.07 135)', name: 'Titus' },
  { init: 'C', tier: 'A', el: 'Wind', col: 'oklch(0.80 0.07 175)', name: 'Cornelia' },
  { init: 'M', tier: 'A', el: 'Light', col: 'oklch(0.90 0.06 95)', name: 'Maximus' },
];
const tierCol = (t: string) => (t === 'S' ? 'oklch(0.74 0.12 82)' : 'oklch(0.80 0.02 250)');
---

<figure class={`gameshot ${cls}`}>
  <div class="gameshot-frame">
    <div class="gameshot-bar">
      <span class="dots"><i></i><i></i><i></i></span>
      <span class="gameshot-title">ROMESTEAD · {label[scene]}</span>
    </div>
    <div class="gameshot-screen">
      <svg viewBox="0 0 800 450" role="img" aria-label={alt} preserveAspectRatio="xMidYMid slice">
        <defs>
          <radialGradient id="vig" cx="50%" cy="38%" r="75%">
            <stop offset="0%" stop-color="oklch(0.96 0.02 82)" />
            <stop offset="100%" stop-color="oklch(0.86 0.04 78)" />
          </radialGradient>
          <linearGradient id="goldgrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="oklch(0.82 0.10 85)" />
            <stop offset="100%" stop-color="oklch(0.66 0.12 78)" />
          </linearGradient>
        </defs>

        <!-- common background -->
        <rect width="800" height="450" fill="url(#vig)" />
        <rect x="0" y="0" width="800" height="450" fill="none" stroke="oklch(0.74 0.12 82 / 0.25)" stroke-width="2" />

        {scene === 'base' && (
          <g>
            <!-- top resource bar -->
            <rect x="0" y="0" width="800" height="46" fill="oklch(0.24 0.02 60 / 0.88)" />
            <g font-family="Cinzel, serif" font-size="15" fill="oklch(0.95 0.02 82)">
              <g transform="translate(24,23)">
                <circle r="11" fill="oklch(0.70 0.02 250)" /><text x="0" y="5" text-anchor="middle" font-size="12">◆</text>
                <text x="20" y="5" font-family="Newsreader, serif">1.2K Stone</text>
              </g>
              <g transform="translate(210,23)">
                <circle r="11" fill="oklch(0.78 0.10 120)" /><text x="0" y="5" text-anchor="middle" font-size="13">🌾</text>
                <text x="20" y="5" font-family="Newsreader, serif">8.4K Food</text>
              </g>
              <g transform="translate(396,23)">
                <rect x="-11" y="-11" width="22" height="22" rx="4" fill="oklch(0.66 0.16 300)" /><text x="0" y="5" text-anchor="middle" font-size="12">♦</text>
                <text x="20" y="5" font-family="Newsreader, serif">340 Gems</text>
              </g>
              <text x="776" y="5" text-anchor="end" font-family="Newsreader, serif" fill="oklch(0.74 0.12 82)">Day 1</text>
            </g>
            <!-- horizon -->
            <line x1="0" y1="320" x2="800" y2="320" stroke="oklch(0.66 0.12 78 / 0.5)" stroke-width="2" />
            <!-- buildings -->
            <g>
              <!-- Granary -->
              <rect x="120" y="240" width="120" height="80" rx="6" fill="oklch(0.84 0.04 78)" stroke="oklch(0.66 0.12 78)" stroke-width="2" />
              <path d="M110 240 L180 200 L250 240 Z" fill="oklch(0.50 0.18 27)" />
              <text x="180" y="300" text-anchor="middle" font-family="Newsreader, serif" font-size="14" fill="oklch(0.32 0.02 60)">Granary</text>
              <!-- Principia (center, larger) -->
              <rect x="330" y="210" width="150" height="110" rx="6" fill="oklch(0.90 0.03 80)" stroke="url(#goldgrad)" stroke-width="3" />
              <path d="M318 210 L405 158 L492 210 Z" fill="oklch(0.45 0.17 27)" />
              <rect x="395" y="120" width="20" height="44" fill="oklch(0.45 0.17 27)" />
              <path d="M415 126 L455 138 L415 150 Z" fill="url(#goldgrad)" />
              <text x="405" y="285" text-anchor="middle" font-family="Cinzel, serif" font-size="15" fill="oklch(0.40 0.15 27)">PRINCIPIA</text>
              <!-- Wall -->
              <rect x="560" y="250" width="130" height="70" rx="4" fill="oklch(0.84 0.04 78)" stroke="oklch(0.66 0.12 78)" stroke-width="2" />
              <path d="M560 250 h130 v12 h-14 v-6 h-14 v6 h-14 v-6 h-14 v6 h-14 v-6 h-14 v6 h-14 v-6 h-14 v6 h-14 Z" fill="oklch(0.74 0.05 75)" />
              <text x="625" y="312" text-anchor="middle" font-family="Newsreader, serif" font-size="14" fill="oklch(0.32 0.02 60)">Wall</text>
            </g>
            <!-- governor avatar -->
            <g transform="translate(60,360)">
              <circle r="26" fill="oklch(0.50 0.18 27)" />
              <text x="0" y="7" text-anchor="middle" font-family="Cinzel, serif" font-size="20" fill="oklch(0.95 0.02 82)">G</text>
              <text x="36" y="6" font-family="Newsreader, serif" font-size="14" fill="oklch(0.40 0.15 27)">Governor</text>
            </g>
          </g>
        )}

        {scene === 'hero-roster' && (
          <g>
            {roster.map((h, i) => {
              const col = i % 3;
              const row = Math.floor(i / 3);
              const x = 90 + col * 220;
              const y = 70 + row * 170;
              const sel = i === 0;
              return (
                <g transform={`translate(${x},${y})`}>
                  <rect x="-80" y="-60" width="160" height="140" rx="12"
                    fill={sel ? 'oklch(0.95 0.02 82)' : 'oklch(0.90 0.03 80)'}
                    stroke={sel ? 'url(#goldgrad)' : 'oklch(0.74 0.05 75)'} stroke-width={sel ? 4 : 2} />
                  <circle cx="0" cy="-12" r="34" fill={h.col} stroke="oklch(0.74 0.12 82)" stroke-width="2" />
                  <text x="0" y="-2" text-anchor="middle" font-family="Cinzel, serif" font-size="30" fill="oklch(0.24 0.02 60)">{h.init}</text>
                  <text x="0" y="42" text-anchor="middle" font-family="Newsreader, serif" font-size="15" fill="oklch(0.32 0.02 60)">{h.name}</text>
                  <text x="0" y="62" text-anchor="middle" font-family="Newsreader, serif" font-size="12" fill="oklch(0.50 0.18 27)">{h.el}</text>
                  <circle cx="58" cy="-50" r="16" fill={tierCol(h.tier)} />
                  <text x="58" y="-44" text-anchor="middle" font-family="Cinzel, serif" font-size="17" fill="oklch(0.24 0.02 60)">{h.tier}</text>
                </g>
              );
            })}
          </g>
        )}

        {scene === 'formation' && (
          <g>
            <!-- ground -->
            <rect x="0" y="330" width="800" height="120" fill="oklch(0.84 0.04 78 / 0.6)" />
            <!-- shield wall: 3 rows x 5 -->
            {[0,1,2].flatMap((r) => (
              [0,1,2,3,4].map((c) => {
                const sx = 180 + c * 95;
                const sy = 250 - r * 42;
                return (
                  <g transform={`translate(${sx},${sy})`}>
                    <path d="M0,-26 L18,-18 L18,6 Q18,26 0,34 Q-18,26 -18,6 L-18,-18 Z"
                      fill={r === 0 ? 'oklch(0.74 0.12 82)' : 'oklch(0.82 0.04 80)'} stroke="oklch(0.45 0.17 27)" stroke-width="2" />
                    <path d="M0,-14 L10,-9 L10,4 Q10,14 0,19 Q-10,14 -10,4 L-10,-9 Z" fill="oklch(0.45 0.17 27)" />
                  </g>
                );
              })
            ))}
            <!-- commander banner -->
            <g transform="translate(400,150)">
              <rect x="-3" y="-70" width="6" height="120" fill="oklch(0.45 0.17 27)" />
              <path d="M3 -66 L54 -54 L3 -42 Z" fill="url(#goldgrad)" />
              <text x="0" y="-76" text-anchor="middle" font-family="Cinzel, serif" font-size="14" fill="oklch(0.40 0.15 27)">AURELIA</text>
            </g>
            <!-- flank arrows -->
            <path d="M40 250 Q120 210 250 230" fill="none" stroke="oklch(0.50 0.18 27)" stroke-width="3" marker-end="url(#ah)" />
            <path d="M760 250 Q680 210 550 230" fill="none" stroke="oklch(0.50 0.18 27)" stroke-width="3" />
            <text x="140" y="200" font-family="Newsreader, serif" font-size="14" fill="oklch(0.40 0.15 27)">Flank ↗</text>
            <text x="660" y="200" text-anchor="end" font-family="Newsreader, serif" font-size="14" fill="oklch(0.40 0.15 27)">↖ Flank</text>
            <defs>
              <marker id="ah" markerWidth="10" markerHeight="10" refX="6" refY="3" orient="auto">
                <path d="M0,0 L6,3 L0,6 Z" fill="oklch(0.50 0.18 27)" />
              </marker>
            </defs>
          </g>
        )}

        {scene === 'beast' && (
          <g>
            <!-- HP bar -->
            <rect x="240" y="30" width="320" height="22" rx="11" fill="oklch(0.24 0.02 60 / 0.4)" />
            <rect x="244" y="34" width="220" height="14" rx="7" fill="oklch(0.50 0.18 27)" />
            <text x="400" y="24" text-anchor="middle" font-family="Cinzel, serif" font-size="15" fill="oklch(0.40 0.15 27)">VERGE WYRM</text>
            <!-- boss silhouette -->
            <g transform="translate(400,250)">
              <path d="M-150,40 Q-120,-30 -60,-10 Q-30,-60 30,-30 Q90,-70 150,-10 Q170,30 120,50 Q60,30 20,55 Q-40,30 -90,55 Q-140,40 -150,40 Z"
                fill="oklch(0.40 0.10 300)" stroke="oklch(0.66 0.12 78)" stroke-width="2" />
              <circle cx="-90" cy="-5" r="7" fill="oklch(0.90 0.12 95)" />
              <circle cx="-40" cy="-15" r="7" fill="oklch(0.90 0.12 95)" />
              <circle cx="40" cy="-10" r="7" fill="oklch(0.90 0.12 95)" />
            </g>
            <!-- party -->
            {[0,1,2].map((i) => (
              <g transform={`translate(${300 + i * 100},400)`}>
                <circle r="22" fill={roster[i].col} stroke="oklch(0.74 0.12 82)" stroke-width="2" />
                <text x="0" y="6" text-anchor="middle" font-family="Cinzel, serif" font-size="18" fill="oklch(0.24 0.02 60)">{roster[i].init}</text>
              </g>
            ))}
            <text x="400" y="430" text-anchor="middle" font-family="Newsreader, serif" font-size="13" fill="oklch(0.32 0.02 60)">Tameable boss · screen-wide AoE</text>
          </g>
        )}

        {scene === 'raid' && (
          <g>
            <!-- trap circle -->
            <circle cx="400" cy="250" r="150" fill="none" stroke="oklch(0.74 0.12 82)" stroke-width="3" stroke-dasharray="10 8" />
            <circle cx="400" cy="250" r="90" fill="oklch(0.74 0.12 82 / 0.12)" stroke="oklch(0.74 0.12 82)" stroke-width="2" />
            <!-- rally flag -->
            <g transform="translate(400,250)">
              <rect x="-3" y="-90" width="6" height="120" fill="oklch(0.45 0.17 27)" />
              <path d="M3 -86 L48 -74 L3 -62 Z" fill="url(#goldgrad)" />
            </g>
            <!-- damage numbers -->
            <text x="470" y="180" font-family="Cinzel, serif" font-size="26" fill="oklch(0.66 0.12 78)">−2.4M</text>
            <text x="300" y="150" font-family="Cinzel, serif" font-size="20" fill="oklch(0.66 0.12 78)">−1.1M</text>
            <!-- beast pack icons -->
            {[0,1,2].map((i) => (
              <g transform={`translate(${250 + i * 70},350)`}>
                <circle r="20" fill={roster[i].col} stroke="oklch(0.74 0.12 82)" stroke-width="2" />
                <text x="0" y="6" text-anchor="middle" font-family="Cinzel, serif" font-size="16" fill="oklch(0.24 0.02 60)">{roster[i].init}</text>
              </g>
            ))}
            <!-- timer -->
            <g transform="translate(660,60)">
              <rect x="-46" y="-18" width="92" height="36" rx="8" fill="oklch(0.24 0.02 60 / 0.85)" />
              <text x="0" y="6" text-anchor="middle" font-family="Cinzel, serif" font-size="18" fill="oklch(0.74 0.12 82)">0:08</text>
            </g>
            <text x="400" y="420" text-anchor="middle" font-family="Newsreader, serif" font-size="13" fill="oklch(0.32 0.02 60)">Rally bonus window · Drusus + Octavia</text>
          </g>
        )}

        <!-- corner ticks -->
        <g stroke="oklch(0.74 0.12 82)" stroke-width="3" fill="none">
          <path d="M16 16 h22 M16 16 v22" />
          <path d="M784 16 h-22 M784 16 v22" />
          <path d="M16 434 h22 M16 434 v-22" />
          <path d="M784 434 h-22 M784 434 v-22" />
        </g>
      </svg>
    </div>
  </div>
  {caption && <figcaption>{pick(caption, locale)}</figcaption>}
</figure>

<style>
  .gameshot {
    margin: 2rem auto;
    max-width: 42rem;
  }
  .gameshot-frame {
    border: 1px solid oklch(0.74 0.12 82 / 0.6);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 18px 40px -20px oklch(0.24 0.02 60 / 0.55);
    background: oklch(0.24 0.02 60);
  }
  .gameshot-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.9rem;
    background: oklch(0.24 0.02 60);
    border-bottom: 1px solid oklch(0.74 0.12 82 / 0.3);
  }
  .gameshot-bar .dots {
    display: inline-flex;
    gap: 0.35rem;
  }
  .gameshot-bar .dots i {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: oklch(0.74 0.12 82 / 0.7);
  }
  .gameshot-bar .dots i:first-child { background: oklch(0.50 0.18 27); }
  .gameshot-bar .dots i:nth-child(2) { background: oklch(0.80 0.10 85); }
  .gameshot-title {
    font-family: 'Cinzel', Georgia, serif;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: oklch(0.95 0.02 82);
  }
  .gameshot-screen {
    aspect-ratio: 16 / 9;
    background: oklch(0.92 0.03 80);
  }
  .gameshot-screen svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .gameshot figcaption {
    margin-top: 0.6rem;
    text-align: center;
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 0.9rem;
    color: oklch(0.45 0.02 60);
  }
</style>
