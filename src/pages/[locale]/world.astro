---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getUi } from '../../i18n/ui';
import { LOCALES, link, pick, media, type Locale } from '../../i18n/utils';
import { ogPath } from '../../lib/og';
import { WORLD } from '../../content/world';
import { SITE } from '../../consts';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const ui = getUi(locale);
const path = '/world';
const intro = pick(WORLD.intro, locale);

// Slug used for both filtering and comparison lookups (stable across locales).
const slug = (s: string) => s.toLowerCase().replace(/[^a-z0-9]/g, '');

const biomeData = WORLD.biomes.map((b) => ({
  slug: slug(pick(b.name, 'en')),
  name: pick(b.name, locale),
  stage: b.stage ? pick(b.stage, locale) : '',
  difficulty: b.difficulty ?? 'medium',
  resources: b.resources ?? [],
  creatures: b.creatures ?? [],
  threats: b.threats ? pick(b.threats, locale) : '',
  image: b.image ? media(b.image) : '',
  desc: pick(b.desc, locale),
}));

const diffOptions = ['easy', 'medium', 'hard'] as const;
const resOptions = [
  { key: 'coal', icon: '⛏' },
  { key: 'water', icon: '💧' },
  { key: 'lumber', icon: '🪵' },
] as const;
const typeOptions = WORLD.biomes.map((b) => ({
  slug: slug(pick(b.name, 'en')),
  label: pick(b.name, locale),
}));
---

<Base
  locale={locale}
  title={`${ui['nav.world']} — ${SITE.name}`}
  description={intro}
  path={path}
  breadcrumbs={[{ label: SITE.name, href: link(locale, '/') }, { label: ui['nav.world'] }]}
  ogImage={ogPath(locale, 'world')}
>
  <Header locale={locale} path={path} />
  <main class="mx-auto max-w-7xl px-4 py-12">
    <Breadcrumbs items={[{ label: SITE.name, href: link(locale, '/') }, { label: ui['nav.world'] }]} />
    <div class="mt-6 lg:grid lg:grid-cols-[220px_1fr] lg:gap-8">
      <aside class="hidden lg:block">
        <Sidebar locale={locale} path={path} />
      </aside>
      <div>
        <h1 class="font-display text-3xl font-black text-roman-700">{ui['nav.world']}</h1>
        <p class="mt-4 text-lg leading-relaxed text-ink-700">{intro}</p>

        <section class="mt-10">
          <h2 class="font-display text-2xl font-bold text-roman-700" data-i18n="world.biomes">{ui['world.biomes']}</h2>

          <div class="world-explorer">
            <p class="text-sm font-bold uppercase tracking-wide text-roman-600">{ui['world.filters']}</p>

            <!-- Filter bar -->
            <div class="world-filters">
              <div class="world-filters__row">
                <span class="world-filters__label">{ui['world.filter.search']}</span>
                <input
                  type="search"
                  id="world-search"
                  class="world-filters__search"
                  placeholder={ui['world.filter.search']}
                />
              </div>
              <div class="world-filters__row">
                <span class="world-filters__label">{ui['world.filter.difficulty']}</span>
                {diffOptions.map((d) => (
                  <button type="button" class="world-tag" data-group="difficulty" data-value={d}>
                    {ui['world.difficulty.' + d]}
                  </button>
                ))}
              </div>
              <div class="world-filters__row">
                <span class="world-filters__label">{ui['world.filter.resource']}</span>
                {resOptions.map((r) => (
                  <button type="button" class="world-tag" data-group="resource" data-value={r.key}>
                    {r.icon} {ui['world.res.' + r.key]}
                  </button>
                ))}
              </div>
              <div class="world-filters__row">
                <span class="world-filters__label">{ui['world.filter.type']}</span>
                {typeOptions.map((t) => (
                  <button type="button" class="world-tag" data-group="type" data-value={t.slug}>
                    {t.label}
                  </button>
                ))}
                <button type="button" class="world-clear" id="world-clear">{ui['world.clearfilters']}</button>
              </div>
            </div>

            <!-- Toolbar: result count + view toggle -->
            <div class="world-toolbar">
              <span class="world-toolbar__count" id="world-count"></span>
              <div class="world-viewtoggle" role="group" aria-label={ui['world.view']}>
                <button type="button" data-view="list">{ui['world.view.list']}</button>
                <button type="button" data-view="card">{ui['world.view.card']}</button>
              </div>
            </div>

            <!-- Biome grid -->
            <div class="biome-grid" id="biome-grid" data-view="card">
              {WORLD.biomes.map((b, i) => {
                const s = slug(pick(b.name, 'en'));
                const res = (b.resources ?? []).join(' ').toLowerCase();
                return (
                  <article
                    class="biome-card"
                    data-name={pick(b.name, locale).toLowerCase()}
                    data-difficulty={b.difficulty ?? 'medium'}
                    data-resources={res}
                    data-type={s}
                    data-biome={s}
                  >
                    {b.image && (
                      <img src={media(b.image)} alt={pick(b.name, locale)} loading="lazy" class="biome-card__img" />
                    )}
                    <div class="biome-card__body">
                      <div class="biome-card__head">
                        <h3 class="biome-card__title">{pick(b.name, locale)}</h3>
                        <span class={`diff-pill diff-pill--${b.difficulty ?? 'medium'}`}>
                          {ui['world.difficulty.' + (b.difficulty ?? 'medium')]}
                        </span>
                      </div>
                      <p class="mt-1 text-xs font-semibold text-roman-600">
                        {i + 1}. {b.stage ? pick(b.stage, locale) : ''}
                      </p>
                      <p class="biome-card__desc">{pick(b.desc, locale)}</p>
                      {b.threats && (
                        <p class="mt-3 rounded bg-roman-600/10 px-3 py-2 text-xs font-semibold text-roman-600">
                          ⚔ {pick(b.threats, locale)}
                        </p>
                      )}
                      {b.resources && b.resources.length > 0 && (
                        <div class="mt-3">
                          <p class="text-[11px] font-bold uppercase tracking-wide text-ink-500">{ui['world.resources']}</p>
                          <div class="mt-1 flex flex-wrap gap-1.5">
                            {b.resources.map((r) => (
                              <span class="rounded-full bg-gold-600/15 px-2 py-0.5 text-[11px] font-medium text-gold-700">{r}</span>
                            ))}
                          </div>
                        </div>
                      )}
                      {b.creatures && b.creatures.length > 0 && (
                        <div class="mt-3">
                          <p class="text-[11px] font-bold uppercase tracking-wide text-ink-500">{ui['world.creatures']}</p>
                          <div class="mt-1 flex flex-wrap gap-1.5">
                            {b.creatures.map((c) => (
                              <span class="rounded-full bg-roman-600/12 px-2 py-0.5 text-[11px] font-medium text-roman-600">{c}</span>
                            ))}
                          </div>
                        </div>
                      )}
                      {b.notes && (
                        <ul class="biome-card__notes mt-3 space-y-1 text-xs text-ink-600/90">
                          {pick(b.notes, locale).map((n) => (
                            <li class="flex gap-1.5"><span class="text-gold-600">•</span><span>{n}</span></li>
                          ))}
                        </ul>
                      )}
                      <label class="biome-compare">
                        <input type="checkbox" data-compare={s} /> {ui['world.addcompare']}
                      </label>
                    </div>
                  </article>
                );
              })}
            </div>

            <div class="world-empty" id="world-empty" hidden>{ui['world.noresults']}</div>

            <!-- Comparison tray -->
            <div class="world-compare-tray" id="world-compare-tray" hidden>
              <span class="world-compare-tray__count" id="world-compare-count"></span>
              <span class="world-compare-tray__spacer"></span>
              <button type="button" class="world-compare-tray__clear" id="world-compare-clear">{ui['world.compare.clear']}</button>
              <button type="button" class="world-compare-tray__go" id="world-compare-go" disabled>{ui['world.compare']}</button>
            </div>

            <!-- Comparison table output -->
            <div class="world-compare-output" id="world-compare-output" hidden></div>
          </div>
        </section>
      </div>
    </div>
  </main>
  <Footer locale={locale} />
</Base>

<script is:inline define:vars={{
  BIOMES: biomeData,
  UI: getUi(locale),
  RESOURCE_MATCH: { coal: ['coal'], water: ['water'], lumber: ['wood', 'lumber'] },
}}>
(function () {
  // BIOMES, UI and RESOURCE_MATCH are injected via define:vars.
  const grid = document.getElementById('biome-grid');
  const cards = Array.from(grid.querySelectorAll('.biome-card'));
  const search = document.getElementById('world-search');
  const countEl = document.getElementById('world-count');
  const empty = document.getElementById('world-empty');
  const tags = Array.from(document.querySelectorAll('.world-tag'));
  const clearBtn = document.getElementById('world-clear');
  const viewBtns = Array.from(document.querySelectorAll('.world-viewtoggle button'));
  const compareBoxes = Array.from(document.querySelectorAll('[data-compare]'));
  const tray = document.getElementById('world-compare-tray');
  const trayCount = document.getElementById('world-compare-count');
  const trayGo = document.getElementById('world-compare-go');
  const trayClear = document.getElementById('world-compare-clear');
  const output = document.getElementById('world-compare-output');

  const active = { difficulty: new Set(), resource: new Set(), type: new Set() };
  let searchTerm = '';
  let selected = [];

  function esc(s) {
    return String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
  }

  function applyFilters() {
    let visible = 0;
    cards.forEach((card) => {
      const name = (card.getAttribute('data-name') || '').toLowerCase();
      const diff = card.getAttribute('data-difficulty') || '';
      const res = (card.getAttribute('data-resources') || '').split(' ');
      const type = card.getAttribute('data-type') || '';
      const okSearch = !searchTerm || name.includes(searchTerm);
      const okDiff = active.difficulty.size === 0 || active.difficulty.has(diff);
      const okType = active.type.size === 0 || active.type.has(type);
      let okRes = active.resource.size === 0;
      if (!okRes) {
        active.resource.forEach((key) => {
          const matches = RESOURCE_MATCH[key] || [key];
          if (matches.some((m) => res.includes(m))) okRes = true;
        });
      }
      const show = okSearch && okDiff && okType && okRes;
      card.classList.toggle('is-hidden', !show);
      if (show) visible++;
    });
    countEl.textContent = visible + ' / ' + cards.length;
    empty.hidden = visible !== 0;
  }

  tags.forEach((btn) => {
    btn.addEventListener('click', () => {
      const group = btn.getAttribute('data-group');
      const val = btn.getAttribute('data-value');
      btn.classList.toggle('is-active');
      if (btn.classList.contains('is-active')) active[group].add(val);
      else active[group].delete(val);
      applyFilters();
    });
  });

  search.addEventListener('input', () => {
    searchTerm = (search.value || '').toLowerCase().trim();
    applyFilters();
  });

  clearBtn.addEventListener('click', () => {
    active.difficulty.clear();
    active.resource.clear();
    active.type.clear();
    searchTerm = '';
    search.value = '';
    tags.forEach((t) => t.classList.remove('is-active'));
    applyFilters();
  });

  // View toggle (persisted)
  function setView(v) {
    grid.setAttribute('data-view', v);
    viewBtns.forEach((b) => b.classList.toggle('is-active', b.getAttribute('data-view') === v));
    try { localStorage.setItem('romestead-world-view', v); } catch (e) {}
  }
  let savedView = 'card';
  try { savedView = localStorage.getItem('romestead-world-view') || 'card'; } catch (e) {}
  setView(savedView);
  viewBtns.forEach((b) => b.addEventListener('click', () => setView(b.getAttribute('data-view'))));

  // Comparison
  function updateTray() {
    tray.hidden = selected.length === 0;
    trayCount.textContent = selected.length + ' / 3';
    trayGo.disabled = selected.length < 2;
  }
  function renderCompare() {
    if (selected.length < 2) {
      output.hidden = true;
      output.innerHTML = '';
      return;
    }
    const cols = selected.map((s) => BIOMES.find((b) => b.slug === s)).filter(Boolean);
    let html =
      '<table class="world-compare-table"><thead><tr><th></th>' +
      cols.map((c) => '<th>' + esc(c.name) + '</th>').join('') +
      '</tr></thead><tbody>';
    const row = (label, fn) =>
      '<tr><th>' + esc(label) + '</th>' + cols.map((c) => '<td>' + fn(c) + '</td>').join('') + '</tr>';
    html += row(UI['world.stage'], (c) => esc(c.stage));
    html += row(
      UI['world.difficulty'],
      (c) => '<span class="diff-pill diff-pill--' + c.difficulty + '">' + esc(UI['world.difficulty.' + c.difficulty]) + '</span>'
    );
    html += row(
      UI['world.resources'],
      (c) =>
        '<div class="cmp-pills">' +
        c.resources.map((r) => '<span class="rounded-full bg-gold-600/15 px-2 py-0.5 text-[11px] font-medium text-gold-700">' + esc(r) + '</span>').join('') +
        '</div>'
    );
    html += row(
      UI['world.creatures'],
      (c) =>
        '<div class="cmp-pills">' +
        c.creatures.map((r) => '<span class="rounded-full bg-roman-600/12 px-2 py-0.5 text-[11px] font-medium text-roman-600">' + esc(r) + '</span>').join('') +
        '</div>'
    );
    html += row(UI['world.threats'], (c) => esc(c.threats));
    html += '</tbody></table>';
    output.innerHTML = html;
    output.hidden = false;
  }
  compareBoxes.forEach((box) => {
    box.addEventListener('change', () => {
      const slug = box.getAttribute('data-compare');
      if (box.checked) {
        if (selected.length >= 3) {
          box.checked = false;
          trayCount.textContent = UI['world.compare.max3'];
          return;
        }
        selected.push(slug);
      } else {
        selected = selected.filter((s) => s !== slug);
      }
      updateTray();
      renderCompare();
    });
  });
  trayGo.addEventListener('click', () => {
    if (selected.length < 2) return;
    renderCompare();
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
  trayClear.addEventListener('click', () => {
    selected = [];
    compareBoxes.forEach((b) => (b.checked = false));
    updateTray();
    output.hidden = true;
    output.innerHTML = '';
  });

  applyFilters();
  updateTray();
})();
</script>
