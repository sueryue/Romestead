---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getUi } from '../../i18n/ui';
import { LOCALES, localize, pick, type Locale } from '../../i18n/utils';
import { WORLD } from '../../content/world';
import { SITE } from '../../consts';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const ui = getUi(locale);
const path = '/world';
const intro = pick(WORLD.intro, locale);
---

<Base
  locale={locale}
  title={`${ui['nav.world']} — ${SITE.name}`}
  description={intro}
  path={path}
>
  <Header locale={locale} path={path} />
  <main class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="font-display text-3xl font-black text-roman-700">{ui['nav.world']}</h1>
    <p class="mt-4 text-lg leading-relaxed text-ink-700">{intro}</p>

    <figure class="my-8 flex flex-col items-center">
      <div class="w-full max-w-[320px] rounded-lg border border-gold-600/40">
        <img src={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}og-image.png`} alt="Crest of the Stead" width="320" height="168" class="h-auto w-full rounded-lg" />
      </div>
      <figcaption class="mt-2 text-xs text-ink-700/60">Crest of the Stead</figcaption>
    </figure>

    <section class="mt-8">
      <h2 class="font-display text-2xl font-bold text-roman-700" data-i18n="world.regions">{ui['world.regions']}</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {WORLD.regions.map((r) => (
          <div class="reveal-ready rounded-lg border border-gold-600/30 bg-parchment-50 p-5 shadow-sm">
            <h3 class="font-display text-lg font-bold text-ink-800">{pick(r.name, locale)}</h3>
            <p class="mt-2 text-sm text-ink-700/80">{pick(r.desc, locale)}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-10">
      <h2 class="font-display text-2xl font-bold text-roman-700" data-i18n="world.factions">{ui['world.factions']}</h2>
      <div class="mt-4 space-y-4">
        {WORLD.factions.map((f) => (
          <div class="reveal-ready rounded-lg border border-gold-600/30 bg-parchment-50 p-5 shadow-sm">
            <div class="flex items-center justify-between">
              <h3 class="font-display text-lg font-bold text-ink-800">{pick(f.name, locale)}</h3>
              <span class="rounded bg-roman-600/10 px-2 py-0.5 text-xs font-semibold text-roman-600">{f.element}</span>
            </div>
            <p class="mt-2 text-sm text-ink-700/80">⚔ {pick(f.counter, locale)}</p>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</Base>
