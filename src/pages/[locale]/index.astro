---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LiveStats from '../../components/LiveStats.astro';
import YouTube from '../../components/YouTube.astro';
import { getUi } from '../../i18n/ui';
import { LOCALES, link, pick, media, type Locale } from '../../i18n/utils';
import { GUIDES } from '../../content/guides';
import { ENTRIES, entriesByKind } from '../../content/heroes';
import { WORLD } from '../../content/world';
import { STORE, SITE } from '../../consts';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const ui = getUi(locale);
const path = '/';
const intro = pick(WORLD.intro, locale);
const gods = entriesByKind('god');
const bosses = entriesByKind('boss');
const featuredVideos = [
  { id: 'JAnaIQkwYOo', title: { en: 'Official Launch Trailer', fr: 'Bande-annonce de lancement', de: 'Launch-Trailer', es: 'Tráiler de lanzamiento', it: 'Trailer di lancio ufficiale' } },
  { id: 'ALzGWccYmt0', title: { en: 'Community Town Showcase', fr: 'Showcase communautaire', de: 'Community-Showcase', es: 'Showcase comunitario', it: 'Showcase della community' } },
];
---

<Base
  locale={locale}
  title={`${SITE.name} — ${ui['footer.tagline']}`}
  description={pick(SITE.description, locale)}
  path={path}
  jsonLd={{
    '@type': 'VideoGame',
    name: SITE.name,
    description: SITE.description,
    genre: 'Action-Adventure',
    gamePlatform: ['PC', 'Steam'],
    numberOfPlayers: '1-8',
    inLanguage: locale,
  }}
>
  <Header locale={locale} path={path} />

  <main class="mx-auto max-w-6xl px-4">
    <!-- HERO: text + real launch trailer -->
    <section class="grid items-center gap-8 py-12 md:grid-cols-2">
      <div class="reveal-ready">
        <p class="font-display text-sm uppercase tracking-[0.3em] text-gold-600" data-i18n="hero.eyebrow">{ui['hero.eyebrow']}</p>
        <h1 class="mt-3 font-display text-4xl font-black leading-tight text-roman-700 md:text-5xl">
          {SITE.name}
        </h1>
        <p class="mt-4 max-w-md text-lg text-ink-700">{intro}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={STORE.steam}
            target="_blank"
            rel="noopener"
            data-i18n="cta.play"
            class="w-full rounded bg-roman-600 px-5 py-2.5 text-center font-semibold text-parchment-50 transition-colors hover:bg-roman-500 sm:w-auto"
          >
            {ui['cta.play']}
          </a>
          <a
            href={link(locale, '/guides')}
            data-i18n="cta.read"
            class="w-full rounded border border-gold-600/50 px-5 py-2.5 text-center font-semibold text-roman-600 transition-colors hover:bg-gold-400/10 sm:w-auto"
          >
            {ui['cta.read']}
          </a>
        </div>
        <div class="mt-6"><LiveStats locale={locale} /></div>
      </div>

      <div class="reveal-ready">
        <YouTube id="JAnaIQkwYOo" title={pick(SITE.description, locale)} class="shadow-xl" />
      </div>
    </section>

    <!-- PLAYER GUIDES & VIDEOS -->
    <section class="py-10">
      <h2 class="font-display text-2xl font-bold text-roman-700">{ui['playerGuides']}</h2>
      <div class="mt-6 grid gap-6 lg:grid-cols-2">
        {featuredVideos.map((v) => (
          <div class="reveal-ready">
            <YouTube id={v.id} title={pick(v.title, locale)} />
            <a
              href={`https://www.youtube.com/watch?v=${v.id}`}
              target="_blank"
              rel="noopener"
              class="mt-2 inline-block text-sm font-semibold text-roman-600 hover:underline"
            >{ui['watchYoutube']} ↗</a>
          </div>
        ))}
      </div>
    </section>

    <!-- GUIDES GRID -->
    <section class="py-10">
      <div class="flex items-end justify-between">
        <h2 class="font-display text-2xl font-bold text-roman-700">{ui['nav.guides']}</h2>
        <a href={link(locale, '/guides')} class="text-sm text-roman-600 hover:underline">{ui['cta.read']} →</a>
      </div>
      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {GUIDES.map((g) => (
          <a
            href={link(locale, `/guides/${g.slug}`)}
            class="reveal-ready group overflow-hidden rounded-lg border border-gold-600/30 bg-parchment-50 shadow-sm transition-transform hover:-translate-y-1 hover:border-gold-500"
          >
            {g.cover && (
              <img src={media(g.cover)} alt={pick(g.title, locale)} loading="lazy" class="h-40 w-full object-cover" />
            )}
            <div class="p-5">
              <div class="mb-3 inline-block rounded bg-gold-400/20 px-2 py-0.5 text-xs font-semibold text-roman-600">
                {ui['cat.' + g.category]}
              </div>
              <h3 class="font-display text-lg font-bold text-ink-800 group-hover:text-roman-600">
                {pick(g.title, locale)}
              </h3>
              <p class="mt-2 text-sm text-ink-700/80">{pick(g.description, locale)}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- GODS & FOES TEASER -->
    <section class="py-10">
      <div class="flex items-end justify-between">
        <h2 class="font-display text-2xl font-bold text-roman-700">{ui['nav.heroes']}</h2>
        <a href={link(locale, '/heroes')} class="text-sm text-roman-600 hover:underline">{ui['cta.read']} →</a>
      </div>
      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {[...gods, ...bosses].slice(0, 6).map((e) => (
          <a
            href={link(locale, `/heroes/${e.slug}`)}
            class="reveal-ready group overflow-hidden rounded-lg border border-gold-600/30 bg-parchment-50 shadow-sm transition-transform hover:-translate-y-1"
          >
            {e.image ? (
              <img src={media(e.image)} alt={e.name} loading="lazy" class="h-36 w-full object-cover" />
            ) : (
              <div class="flex h-36 items-center justify-center bg-ink-800 font-display text-3xl text-gold-400">⚜</div>
            )}
            <div class="p-4">
              <h3 class="font-display text-lg font-bold text-ink-800 group-hover:text-roman-600">{e.name}</h3>
              <p class="text-xs text-ink-700/70">{pick(e.role, locale)}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- WORLD TEASER -->
    <section class="py-10">
      <div class="rounded-lg border border-gold-600/30 bg-ink-800 p-8 text-parchment-100">
        <h2 class="font-display text-2xl font-bold text-gold-400">{ui['nav.world']}</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {WORLD.biomes.map((b) => (
            <div class="overflow-hidden rounded-lg border border-gold-600/20">
              {b.image && <img src={media(b.image)} alt={pick(b.name, locale)} loading="lazy" class="h-32 w-full object-cover" />}
              <div class="p-4">
                <h3 class="font-display text-lg font-bold text-parchment-50">{pick(b.name, locale)}</h3>
                <p class="mt-1 text-sm text-parchment-200/80">{pick(b.desc, locale)}</p>
              </div>
            </div>
          ))}
        </div>
        <a href={link(locale, '/world')} class="mt-6 inline-block text-gold-400 hover:underline">{ui['cta.read']} →</a>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</Base>
