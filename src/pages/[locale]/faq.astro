---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Toc from '../../components/Toc.astro';
import { getUi } from '../../i18n/ui';
import { LOCALES, link, pick, type Locale } from '../../i18n/utils';
import { FAQ } from '../../content/faq';
import { SITE } from '../../consts';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const ui = getUi(locale);
const path = '/faq';
const toc = FAQ.map((f) => ({ id: f.id, label: pick(f.q, locale) }));
---
<Base
  locale={locale}
  title={`${ui['faq.title']} — ${SITE.name}`}
  description={pick(SITE.description, locale)}
  path={path}
>
  <Header locale={locale} path={path} />
  <main class="mx-auto max-w-6xl px-4 py-12">
    <Breadcrumbs items={[{ label: SITE.name, href: link(locale, '/') }, { label: ui['faq.title'] }]} />
    <div class="with-toc mt-6">
      <div>
        <h1 class="font-display text-3xl font-black text-roman-700">{ui['faq.title']}</h1>
        <p class="mt-3 text-lg text-ink-700">{ui['faq.intro']}</p>

        <div class="mt-8">
          {FAQ.map((f) => (
            <div id={f.id} class="faq-item reveal-ready scroll-mt-24">
              <h3>{pick(f.q, locale)}</h3>
              <p>{pick(f.a, locale)}</p>
            </div>
          ))}
        </div>

        <section class="mt-10 rounded-lg border border-gold-600/30 bg-ink-800 p-8 text-parchment-100">
          <h2 class="font-display text-xl font-bold text-gold-400">{ui['seeAlso']}</h2>
          <ul class="mt-4 space-y-2 text-parchment-200">
            <li><a href={link(locale, '/guides')} class="underline hover:text-gold-400">{ui['allGuides']}</a></li>
            <li><a href={link(locale, '/heroes')} class="underline hover:text-gold-400">{ui['nav.heroes']}</a></li>
            <li><a href={link(locale, '/world')} class="underline hover:text-gold-400">{ui['nav.world']}</a></li>
          </ul>
        </section>
      </div>

      <aside class="hidden lg:block">
        <Toc items={toc} title={ui['toc']} />
      </aside>
    </div>
  </main>
  <Footer locale={locale} />
</Base>
