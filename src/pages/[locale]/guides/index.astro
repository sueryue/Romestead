---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getUi } from '../../../i18n/ui';
import { LOCALES, link, pick, type Locale } from '../../../i18n/utils';
import { GUIDES } from '../../../content/guides';
import { SITE } from '../../../consts';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const ui = getUi(locale);
const path = '/guides';
---

<Base
  locale={locale}
  title={`${ui['nav.guides']} — ${SITE.name}`}
  description={SITE.description}
  path={path}
>
  <Header locale={locale} path={path} />
  <main class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="font-display text-3xl font-black text-roman-700">{ui['nav.guides']}</h1>
    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {GUIDES.map((g) => (
        <a
          href={link(locale, `/guides/${g.slug}`)}
          class="reveal-ready group rounded-lg border border-gold-600/30 bg-parchment-50 p-5 shadow-sm transition-transform hover:-translate-y-1 hover:border-gold-500"
        >
          <div class="mb-3 inline-block rounded bg-gold-400/20 px-2 py-0.5 text-xs font-semibold text-roman-600">
            {g.category}
          </div>
          <h2 class="font-display text-lg font-bold text-ink-800 group-hover:text-roman-600">
            {pick(g.title, locale)}
          </h2>
          <p class="mt-2 text-sm text-ink-700/80">{pick(g.description, locale)}</p>
          <p class="mt-3 text-xs text-ink-700/60">↻ {g.updated}</p>
        </a>
      ))}
    </div>
  </main>
  <Footer locale={locale} />
</Base>
