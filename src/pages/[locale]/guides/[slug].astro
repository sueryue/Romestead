---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Toc from '../../../components/Toc.astro';
import Infobox from '../../../components/Infobox.astro';
import Callout from '../../../components/Callout.astro';
import RelatedCards from '../../../components/RelatedCards.astro';
import YouTube from '../../../components/YouTube.astro';
import Gallery from '../../../components/Gallery.astro';
import { getUi } from '../../../i18n/ui';
import { LOCALES, link, pick, media, type Locale } from '../../../i18n/utils';
import { GUIDES, getGuide } from '../../../content/guides';
import { SITE } from '../../../consts';

export function getStaticPaths() {
  return LOCALES.flatMap((locale) =>
    GUIDES.map((g) => ({ params: { locale, slug: g.slug } }))
  );
}

const { locale, slug } = Astro.params as { locale: Locale; slug: string };
const guide = getGuide(slug)!;
const ui = getUi(locale);
const path = `/guides/${slug}`;
const sections = pick(guide.sections, locale);

function slugify(str: string): string {
  return str
    .toLowerCase()
    .replace(/['’]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

const toc = sections.map((s) => ({ id: slugify(s.h), label: s.h }));
const related = GUIDES.filter((g) => g.slug !== slug).slice(0, 3).map((g) => ({
  href: link(locale, `/guides/${g.slug}`),
  title: pick(g.title, locale),
  desc: pick(g.description, locale),
  image: g.cover,
}));
const galleryItems = (guide.gallery ?? []).map((src) => ({
  src,
  alt: guide.title,
  caption: undefined as never,
}));
---

<Base
  locale={locale}
  title={`${pick(guide.title, locale)} — ${SITE.name}`}
  description={pick(guide.description, locale)}
  path={path}
  type="article"
  publishedTime={guide.updated}
  jsonLd={{
    '@type': 'Article',
    headline: pick(guide.title, locale),
    description: pick(guide.description, locale),
    datePublished: guide.updated,
    inLanguage: locale,
    author: { '@type': 'Organization', name: SITE.author },
    publisher: { '@type': 'Organization', name: SITE.name },
  }}
>
  <Header locale={locale} path={path} />
  <main class="mx-auto max-w-6xl px-4 py-12">
    <Breadcrumbs
      items={[
        { label: SITE.name, href: link(locale, '/') },
        { label: ui['nav.guides'], href: link(locale, '/guides') },
        { label: pick(guide.title, locale) },
      ]}
    />
    <div class="with-toc mt-6">
      <article class="reveal-ready">
        <p class="font-display text-xs uppercase tracking-[0.3em] text-gold-600">{ui['cat.' + guide.category]}</p>
        <h1 class="mt-2 font-display text-3xl font-black text-roman-700">{pick(guide.title, locale)}</h1>
        <p class="mt-3 text-lg text-ink-700">{pick(guide.description, locale)}</p>

        {guide.cover && (
          <img src={media(guide.cover)} alt={pick(guide.title, locale)} class="mt-6 w-full rounded-xl border border-gold-600/20" />
        )}

        {guide.video && (
          <div class="mt-6">
            <YouTube id={guide.video.id} title={pick(guide.video.title, locale)} />
            <a
              href={`https://www.youtube.com/watch?v=${guide.video.id}`}
              target="_blank"
              rel="noopener"
              class="mt-2 inline-block text-sm font-semibold text-roman-600 hover:underline"
            >{ui['watchYoutube']} ↗</a>
          </div>
        )}

        {guide.tip && (
          <Callout variant="tip" title={ui['hero.tip']} class="mt-6">{pick(guide.tip, locale)}</Callout>
        )}

        <Infobox
          title={ui['atGlance']}
          rows={[
            { label: ui['fCategory'], value: ui['cat.' + guide.category] },
            { label: ui['fUpdated'], value: guide.updated },
          ]}
          class="mt-6 lg:float-right lg:ml-6 lg:mt-0 lg:w-72"
        />

        {sections.map((s, i) => (
          <section id={toc[i].id} class="reveal-ready mt-8 scroll-mt-24">
            <h2 class="font-display text-xl font-bold text-ink-800">{s.h}</h2>
            <div class="mt-3 space-y-3 text-ink-700">
              {s.p.map((para) => <p>{para}</p>)}
            </div>
            {s.media && (
              <img src={media(s.media)} alt={s.h} class="mt-4 w-full rounded-xl border border-gold-600/20" />
            )}
          </section>
        ))}

        {galleryItems.length > 0 && (
          <section class="mt-10">
            <h2 class="font-display text-xl font-bold text-roman-700">{ui['screenshots']}</h2>
            <div class="mt-4">
              <Gallery items={galleryItems} locale={locale} />
            </div>
          </section>
        )}

        <RelatedCards items={related} title={ui['relatedGuides']} class="mt-12 clear-both" />
      </article>

      <aside class="hidden lg:block">
        <Toc items={toc} title={ui['toc']} />
      </aside>
    </div>
  </main>
  <Footer locale={locale} />
</Base>
