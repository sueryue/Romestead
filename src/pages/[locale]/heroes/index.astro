---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getUi } from '../../../i18n/ui';
import { LOCALES, link, pick, type Locale } from '../../../i18n/utils';
import { HEROES } from '../../../content/heroes';
import { SITE } from '../../../consts';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const ui = getUi(locale);
const path = '/heroes';
const tiers = ['S', 'A', 'B', 'C'] as const;
---

<Base
  locale={locale}
  title={`${ui['nav.heroes']} — ${SITE.name}`}
  description={pick(SITE.description, locale)}
  path={path}
>
  <Header locale={locale} path={path} />
  <main class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="font-display text-3xl font-black text-roman-700">{ui['nav.heroes']}</h1>
    {tiers.map((t) => {
      const row = HEROES.filter((h) => h.tier === t);
      if (!row.length) return null;
      return (
        <section class="mt-8">
          <h2 class="font-display text-xl font-bold">
            <span class={`mr-2 inline-block rounded px-2 py-0.5 text-sm text-parchment-50 ${
              t === 'S' ? 'bg-roman-600' : t === 'A' ? 'bg-gold-600' : 'bg-ink-700'
            }`}>{t}</span> <span data-i18n="hero.tier">{ui['hero.tier']}</span>
          </h2>
          <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {row.map((h) => (
              <a
                href={link(locale, `/heroes/${h.slug}`)}
                class="reveal-ready rounded-lg border border-gold-600/30 bg-parchment-50 p-4 shadow-sm transition-transform hover:-translate-y-1"
              >
                <div class="flex items-center gap-3">
                  <div class="flex h-11 w-11 items-center justify-center rounded-full bg-roman-600 font-display text-gold-400">⚔</div>
                  <div>
                    <h3 class="font-display text-lg font-bold">{h.name}</h3>
                    <p class="text-xs text-ink-700/70">{pick(h.role, locale)} · {h.element}</p>
                  </div>
                </div>
                <p class="mt-3 text-sm italic text-ink-700/80">“{pick(h.lead, locale)}”</p>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </main>
  <Footer locale={locale} />
</Base>
