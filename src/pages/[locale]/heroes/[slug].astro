---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Infobox from '../../../components/Infobox.astro';
import Callout from '../../../components/Callout.astro';
import RelatedCards from '../../../components/RelatedCards.astro';
import { getUi } from '../../../i18n/ui';
import { LOCALES, link, pick, media, type Locale } from '../../../i18n/utils';
import { ENTRIES, getEntry } from '../../../content/heroes';
import { SITE } from '../../../consts';

export function getStaticPaths() {
  return LOCALES.flatMap((locale) =>
    ENTRIES.map((e) => ({ params: { locale, slug: e.slug } }))
  );
}

const { locale, slug } = Astro.params as { locale: Locale; slug: string };
const entry = getEntry(slug)!;
const ui = getUi(locale);
const path = `/heroes/${slug}`;
const isBoss = entry.kind === 'boss';
const related = ENTRIES.filter((e) => e.slug !== slug).slice(0, 4).map((e) => ({
  href: link(locale, `/heroes/${e.slug}`),
  title: e.name,
  desc: pick(e.role, locale),
  image: e.image,
}));
---

<Base
  locale={locale}
  title={`${entry.name} — ${SITE.name}`}
  description={pick(entry.bio, locale)}
  path={path}
  type="article"
  jsonLd={{
    '@type': isBoss ? 'Thing' : 'Person',
    name: entry.name,
    description: pick(entry.bio, locale),
    inLanguage: locale,
  }}
>
  <Header locale={locale} path={path} />
  <main class="mx-auto max-w-5xl px-4 py-12">
    <Breadcrumbs
      items={[
        { label: SITE.name, href: link(locale, '/') },
        { label: ui['nav.heroes'], href: link(locale, '/heroes') },
        { label: entry.name },
      ]}
    />
    <article class="mt-6 reveal-ready overflow-hidden rounded-lg border border-gold-600/30 bg-parchment-50 shadow-sm">
      {entry.image && (
        <img src={media(entry.image)} alt={entry.name} class="h-56 w-full object-cover" />
      )}
      <div class="p-8">
        <div class="flex items-center gap-4">
          {!entry.image && (
            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-roman-600 font-display text-2xl text-gold-400">⚜</div>
          )}
          <div>
            <h1 class="font-display text-3xl font-black text-roman-700">{entry.name}</h1>
            <p class="text-sm text-ink-700/70">{pick(entry.role, locale)}</p>
          </div>
          <span class={`ml-auto rounded px-3 py-1 text-xs font-semibold text-parchment-50 ${isBoss ? 'bg-ink-800' : 'bg-gold-600'}`}>
            {isBoss ? ui['heroes.bosses'] : ui['heroes.gods']}
          </span>
        </div>

        {entry.meta && entry.meta.length > 0 && (
          <Infobox title={ui['atGlance']} rows={entry.meta} class="mt-6 lg:float-right lg:ml-6 lg:mt-2 lg:w-72" />
        )}

        <p class="mt-6 text-lg italic leading-relaxed text-ink-700">“{pick(entry.lead, locale)}”</p>
        <p class="mt-4 leading-relaxed text-ink-700">{pick(entry.bio, locale)}</p>
        {entry.flavor && (
          <Callout variant="info" title={entry.name} class="mt-4 clear-both">“{entry.flavor}”</Callout>
        )}
        <Callout variant="tip" title={ui['hero.tip']} class="mt-4 clear-both">{pick(entry.tip, locale)}</Callout>
      </div>
    </article>

    <RelatedCards items={related} title={ui['nav.heroes']} class="mt-12" />
  </main>
  <Footer locale={locale} />
</Base>
