---
import '../styles/global.css';
import { SITE, STORE } from '../consts';
import { getUi } from '../i18n/ui';
import {
  LOCALES,
  LOCALE_HREFLANG,
  LOCALE_OG,
  localize,
  pick,
  type Locale,
} from '../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  path: string; // path WITHOUT locale prefix, e.g. '/guides/beginners-guide'
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
  publishedTime?: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const {
  locale,
  title,
  description,
  path,
  type = 'website',
  jsonLd,
  publishedTime,
  breadcrumbs,
} = Astro.props;

const ui = getUi(locale);

// Each locale self-canonicalizes (never cross-language canonical). Non-indexed
// locales (fr/de/es/it) still emit their own canonical + hreflang alternates and
// are discovered via hreflang from the indexed English URL ˇŞ this avoids the
// cross-language canonical penalty while keeping the sitemap trimmed to en.
const canonTarget = localize(locale, path);
const canon = SITE.url + canonTarget;
const base = import.meta.env.BASE_URL || '';
const absUrl = (href?: string) => {
  const raw = href ?? canonTarget; // last crumb (no href) ˇú current page URL
  const rel = raw.startsWith(base) ? raw.slice(base.length) || '/' : raw;
  return SITE.url + rel;
};
const ogImageAbs = SITE.url + SITE.ogImage;
const geo = SITE.geo[locale] ?? SITE.geo.default;

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.url,
  logo: SITE.url + '/favicon.svg',
  sameAs: [STORE.steam, STORE.discord, STORE.youtube],
};
const siteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: pick(SITE.description, locale),
  inLanguage: LOCALE_HREFLANG[locale],
};
const pageLd = jsonLd
  ? { '@context': 'https://schema.org', ...jsonLd }
  : null;

// Breadcrumb trail (GEO/SEO): mirrors the visible <Breadcrumbs> nav.
const breadcrumbLd = breadcrumbs && breadcrumbs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: c.label,
        item: absUrl(c.href),
      })),
    }
  : null;
---

<!doctype html>
<html lang={locale}>
  <head>
    <script is:inline>document.documentElement.classList.add('js');</script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#2b2620" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={ui['meta.keywords']} />
    <link rel="canonical" href={canon} />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- GEO optimization -->
    <meta name="geo.region" content={geo.region} />
    <meta name="geo.placename" content={geo.placename} />
    <meta name="geo.position" content={geo.position} />
    <meta name="ICBM" content={geo.position} />

    <!-- hreflang alternates (per-locale URLs â†? SEO/GEO) -->
    {LOCALES.map((l) => (
      <link rel="alternate" hreflang={LOCALE_HREFLANG[l]} href={SITE.url + localize(l, path)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={SITE.url + localize('en', path)} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canon} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={LOCALE_OG[locale]} />
    {LOCALES.filter((l) => l !== locale).map((l) => (
      <meta property="og:locale:alternate" content={LOCALE_OG[l]} />
    ))}
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@BeartwigsOfficial" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- Fonts: Cinzel (display) + Newsreader (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700;900&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,600;1,6..72,400&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}favicon.svg`} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
    {pageLd && <script type="application/ld+json" set:html={JSON.stringify(pageLd)} />}
  </head>
  <body>
    <slot />

    <!-- Client scripts: i18n dynamic switch -->
    <script>
      import '../scripts/i18n-client.ts';
    </script>

    <!-- Reveal-on-scroll: add .is-visible when .reveal-ready enters viewport.
         Inline (not bundled) so content can never be left permanently hidden. -->
    <script is:inline>
      (function () {
        var els = document.querySelectorAll('.reveal-ready');
        function revealAll() {
          for (var i = 0; i < els.length; i++) els[i].classList.add('is-visible');
        }
        if (!('IntersectionObserver' in window)) { revealAll(); return; }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
        els.forEach(function (el) { io.observe(el); });
        // Safety net: guarantee content is visible even if observer misbehaves
        setTimeout(revealAll, 2500);
      })();
    </script>
  </body>
</html>
